<?xml version="1.0" encoding="utf-8" ?>
<!--
  ServerSetup.xml
  First-run component that prompts the user to enter the Video Manger server URL.

  Uses a Keyboard node (inline widget, works inside any Group) rather than
  KeyboardDialog (which requires Scene-level placement).

  Interface fields:
    navAction  (assocarray, alwaysNotify) – fires {type:"serverSaved", serverURL:"..."} on success
    isActive   (boolean)                  – set by MainScene after AppendChild so we can
                                           call SetFocus once the node is in the scene tree
-->
<component name="ServerSetup" extends="Group">
    <interface>
        <field id="navAction" type="assocarray" alwaysNotify="true" />
        <field id="isActive"  type="boolean"    value="false" onChange="onActivated" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/ServerSetup.brs" />

    <children>
        <!-- Dark full-screen background -->
        <Rectangle
            id="bg"
            width="1920"
            height="1080"
            color="0x141414FF" />

        <!-- Title -->
        <Label
            id="titleLabel"
            translation="[760, 60]"
            font="font:LargeBoldSystemFont"
            color="0xFFFFFFFF"
            text="Video Manger Setup" />

        <!-- Instruction text -->
        <Label
            id="instructionLabel"
            translation="[340, 130]"
            width="1240"
            font="font:SmallSystemFont"
            color="0xCCCCCCFF"
            wrap="true"
            text="Enter the address of your Video Manger server, then press PLAY to connect.&#10;Example: http://192.168.1.100:8080" />

        <!-- Inline keyboard widget — works inside a Group, unlike KeyboardDialog -->
        <Keyboard
            id="keyboard"
            translation="[340, 210]" />

        <!-- Error / status message (shown when validation fails) -->
        <Label
            id="errorLabel"
            translation="[340, 620]"
            width="1240"
            font="font:SmallSystemFont"
            color="0xFF4444FF"
            text="" />

        <!-- Hint label -->
        <Label
            id="hintLabel"
            translation="[340, 660]"
            font="font:SmallSystemFont"
            color="0x888888FF"
            text="▶  PLAY = connect     ←  BACK = exit" />
    </children>
</component>
