<?xml version="1.0" encoding="utf-8" ?>
<!--
  MainScene.xml
  Root SceneGraph Scene component.

  Manages a navigation stack (array of component nodes).  Each child component
  communicates upward by setting its `navAction` field.  MainScene observes
  that field on every pushed view and routes the action:

    {type:"push",   comp:"ComponentName", params:{...}}  → push a new view
    {type:"back"}                                        → pop current view
    {type:"play",   videoData:{...}}                     → push Player
    {type:"serverSaved", serverURL:"..."}                → save URL, go home
-->
<component name="MainScene" extends="Scene">
    <script type="text/brightscript" uri="pkg:/components/MainScene.brs" />

    <children>
        <!-- Background rectangle fills the entire screen -->
        <Rectangle
            id="background"
            width="1920"
            height="1080"
            color="0x141414FF" />
        <!-- Polls /roku/poll so the web UI can cast a video to the Roku -->
        <Timer id="castPollTimer" repeat="true" duration="2" />
    </children>
</component>
